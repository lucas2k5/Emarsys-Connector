# Server Configuration
PORT=3000
NODE_ENV=development

ENABLE_EMARSYS_UPLOAD=true
TEST_TOKEN=seu_token_de_teste_aqui
ORDERS_DAYS_LOOKBACK=1
VTEX_ORDERS_URL=cscs
# Configurações de Processamento em Lotes (para evitar timeouts)
ORDERS_MAX_PAGES=10
ORDERS_PAGE_SIZE=50
ORDERS_DELAY_MS=300

# Inngest Configuration (Background Jobs) - OPCIONAL
INNGEST_EVENT_KEY=seu_inngest_event_key
INNGEST_SIGNING_KEY=seu_inngest_signing_key
INNGEST_ENV=dev

# Rate Limiting Configuration (opcional)
API_MAX_CONCURRENT=5
API_MIN_TIME=200
PRODUCT_MAX_CONCURRENT=10
PRODUCT_MIN_TIME=100

# Configurações de Processamento de Produtos (Inngest)
PRODUCTS_BATCH_SIZE=20
PRODUCTS_CONCURRENCY=4
PRODUCTS_MIN_TIME_MS=100
PRODUCTS_LOG_EVERY=20
PRODUCTS_INTRA_BATCH_CONCURRENCY=4
PRODUCTS_ERRORS_SAMPLE=10
PRODUCTS_INTER_BATCH_SLEEP_MS=250
PRODUCTS_INTER_CHUNK_SLEEP_MS=1000
INNGEST_CHUNK_SIZE=50
SKIP_INLINE_CSV_GENERATION=true

# VTEX Configuration
VTEX_ACCOUNT_NAME=seu_account_name
VTEX_APP_KEY=seu_app_key
VTEX_APP_TOKEN=seu_app_token
VTEX_BASE_URL=https://{account}.myvtex.com

# EMS Clients Sync
EMS_ENTITY_ID=emsClientsV2
EMS_SYNC_LOOKBACK_HOURS=5

# Emarsys Configuration
# Token fixo para autenticação na API de Sales Data
EMARSYS_SALES_TOKEN=seu_token_fixo_emarsys
# Credenciais WSSE (opcional - para outros endpoints)
EMARSYS_USER=seu_username_emarsys
EMARSYS_SECRET=sua_senha_emarsys
# OU
EMARSYS_USERNAME=seu_username_emarsys
EMARSYS_PASSWORD=sua_senha_emarsys
EMARSYS_ENDPOINT=https://api.emarsys.net/api/v2

# (Removidos IDs de campos específicos de contato; mapeamento usa somente IDs padrão 1,2,3)

