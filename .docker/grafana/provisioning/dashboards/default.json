{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Status Geral",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "title": "Uptime do Processo",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [{ "expr": "time() - process_start_time_seconds", "legendFormat": "Uptime" }],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": null, "color": "green" }] } } }
    },
    {
      "title": "Taxa de Requisições (HTTP)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [{ "expr": "rate(http_requests_total[5m])", "legendFormat": "req/s" }],
      "fieldConfig": { "defaults": { "unit": "pps", "decimals": 2 } }
    },
    {
      "title": "Conexões Ativas",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [{ "expr": "active_connections", "legendFormat": "Ativas" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100 } }
    },
    {
      "title": "Métricas de Performance (RED)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "title": "Latência HTTP (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "Latency P95" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [{ "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "Current Lag" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Node.js Internals",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "title": "Uso de Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "targets": [
        { "expr": "nodejs_heap_size_used_bytes", "legendFormat": "Used" },
        { "expr": "nodejs_heap_size_total_bytes", "legendFormat": "Total" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Garbage Collection (Duration)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "targets": [{ "expr": "rate(nodejs_gc_duration_seconds_sum[5m])", "legendFormat": "{{kind}}" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Active Handles & Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "targets": [
        { "expr": "nodejs_active_handles_total", "legendFormat": "Handles" },
        { "expr": "nodejs_active_requests_total", "legendFormat": "Requests" }
      ]
    },
    {
      "title": "Recursos do Sistema",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "title": "CPU Usage (Process)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [{ "expr": "rate(process_cpu_seconds_total[5m]) * 100", "legendFormat": "CPU %" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "File Descriptors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "process_open_fds", "legendFormat": "Open" },
        { "expr": "process_max_fds", "legendFormat": "Max Limit" }
      ]
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["nodejs", "prometheus"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Node.js Application Dashboard",
  "uid": "nodejs_app_metrics"
}