# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# BASE_URL para uso em produção nos cron jobs (ex: https://seu-dominio.com)
# Se não configurado, usa http://localhost:PORT em desenvolvimento
BASE_URL=

# Database Configuration
SQLITE_DB_PATH=./data/orders.db

# Debug Mode - Pula envio para Emarsys e marca pedidos como isSync=true para teste
DEBUG=false

ENABLE_EMARSYS_UPLOAD=true
VTEX_ORDERS_URL=/_v/orders/list
# URL opcional para deleção de pedidos (override). Se vazio, usa VTEX_BASE_URL/_v/orders/all
VTEX_ORDERS_DELETE=

# Configuração para controlar limpeza automática de pedidos
# true = limpeza habilitada | false = limpeza pausada (padrão recomendado)
ENABLE_ORDER_CLEANUP=false
# Duração em horas para manter registros de pedidos processados (padrão: 720 = 30 dias)
PROCESSED_ORDERS_RETENTION_HOURS=720

# Configurações de Timeout Otimizadas (em milissegundos)
PRODUCTS_TIMEOUT_MS=600000
ORDERS_TIMEOUT_MS=900000

# VTEX Configuration (genérico — mantido para compatibilidade)
VTEX_APP_KEY=seu_app_key
VTEX_APP_TOKEN=seu_app_token
VTEX_BASE_URL=https://{account}.myvtex.com

# VTEX - Hope (store: hope)
# Se preenchido, tem prioridade sobre VTEX_BASE_URL/VTEX_APP_KEY/VTEX_APP_TOKEN acima
VTEX_BASE_URL_HOPE=
VTEX_APP_KEY_HOPE=
VTEX_APP_TOKEN_HOPE=

# URL pública da loja (usada para montar links de SKUs inativos/invisíveis)
STORE_BASE_URL=https://www.hopelingerie.com.br

# VTEX - Hope Resort (store: resort)
# Se preenchido, habilita o sync automático de produtos do Resort no cron
VTEX_BASE_URL_RESORT=
VTEX_APP_KEY_RESORT=
VTEX_APP_TOKEN_RESORT=

# ============================================================
# Hope Resort — VTEX + SFTP (sync de produtos e pedidos)
# ============================================================
RESORT_VTEX_BASE_URL=https://lojahr.vtexcommercestable.com.br
RESORT_VTEX_APP_KEY=
RESORT_VTEX_APP_TOKEN=
RESORT_STORE_BASE_URL=https://www.lojahr.com.br

# SFTP Resort (opcional — se vazio, usa as credenciais SFTP_PRODUCTS_* da Hope)
RESORT_SFTP_HOST=
RESORT_SFTP_PORT=22
RESORT_SFTP_USER=
RESORT_SFTP_PASSWORD=
RESORT_SFTP_REMOTE_DIR=/

# EMS Clients Sync
EMS_ENTITY_ID=emsClientsV2
EMS_SYNC_LOOKBACK_HOURS=5

# EMS Orders Sync
EMS_ORDERS_ENTITY_ID=emsOrdersV2

# Emarsys Configuration
# Token fixo para autenticação na API de Sales Data
EMARSYS_SALES_TOKEN=seu_token_fixo_emarsys
# Credenciais WSSE (opcional - para outros endpoints)
EMARSYS_USER=seu_username_emarsys
EMARSYS_SECRET=sua_senha_emarsys
# OU
EMARSYS_USERNAME=seu_username_emarsys
EMARSYS_PASSWORD=sua_senha_emarsys

# ============================================================
# Emarsys OAuth2 API - PEDIDOS Hope (envio via API, substitui SFTP)
# ============================================================
EMARSYS_OAUTH2_ID=
EMARSYS_OAUTH2_CLIENT_ID=
EMARSYS_OAUTH2_CLIENT_SECRET=
EMARSYS_OAUTH2_TOKEN_ENDPOINT=https://auth.emarsys.net/oauth2/token
EMARSYS_OAUTH2_METADATA_ENDPOINT=https://auth.emarsys.net/.well-known/jwks.json
# URL da API Sales Data Hope (Scarab Research HAPI) — envia CSV como binary via OAuth2
EMARSYS_ORDERS_API_URL=https://admin.scarabresearch.com/hapi/merchant/{MERCHANT_ID_HOPE}/sales-data/api
EMARSYS_ORDERS_API_TIMEOUT=60000

# ============================================================
# Emarsys Orders API - Hope Resort (OAuth2 — credenciais distintas de Hope)
# ============================================================
EMARSYS_OAUTH2_CLIENT_ID_RESORT=
EMARSYS_OAUTH2_CLIENT_SECRET_RESORT=
EMARSYS_OAUTH2_TOKEN_ENDPOINT_RESORT=https://auth.emarsys.net/oauth2/token
EMARSYS_ORDERS_API_URL_RESORT=https://admin.scarabresearch.com/hapi/merchant/{MERCHANT_ID_RESORT}/sales-data/api
EMARSYS_ORDERS_API_TIMEOUT_RESORT=60000

# VTEX - Hope Resort (pedidos — preencher quando as credenciais forem fornecidas)
# Enquanto vazio, o cron de orders Resort não será disparado automaticamente
VTEX_BASE_URL_RESORT_ORDERS=
VTEX_APP_KEY_RESORT_ORDERS=
VTEX_APP_TOKEN_RESORT_ORDERS=

# ============================================================
# SFTP Configuration - PRODUTOS Hope (catálogo para Emarsys)
# ============================================================
SFTP_PRODUCTS_HOST=
SFTP_PRODUCTS_PORT=22
SFTP_PRODUCTS_USERNAME=
SFTP_PRODUCTS_PASSWORD=
SFTP_PRODUCTS_REMOTE_PATH=/catalog/
# Fallback: se as variáveis acima não estiverem definidas,
# usa as variáveis legadas abaixo (SFTP_HOST, SFTP_PORT, etc.)

# ============================================================
# SFTP Configuration - PRODUTOS Hope Resort (store: resort)
# Se não preenchido, faz fallback para SFTP_PRODUCTS_* acima
# ============================================================
SFTP_PRODUCTS_HOST_RESORT=
SFTP_PRODUCTS_PORT_RESORT=22
SFTP_PRODUCTS_USERNAME_RESORT=
SFTP_PRODUCTS_PASSWORD_RESORT=
SFTP_PRODUCTS_REMOTE_PATH_RESORT=/

# ============================================================
# SFTP Configuration - PEDIDOS (orders para Emarsys)
# ============================================================
SFTP_ORDERS_HOST=
SFTP_ORDERS_PORT=22
SFTP_ORDERS_USERNAME=
SFTP_ORDERS_PASSWORD=
SFTP_ORDERS_REMOTE_PATH=/orders/

# ============================================================
# SFTP Legado (fallback se SFTP_PRODUCTS_* não estiver definido)
# ============================================================
SFTP_HOST=sftp.emarsys.net
SFTP_PORT=22
SFTP_USERNAME=seu_usuario_sftp
SFTP_PASSWORD=sua_senha_sftp
SFTP_REMOTE_PATH=/
SFTP_READY_TIMEOUT=20000
SFTP_KEEPALIVE_INTERVAL=15000
SFTP_KEEPALIVE_COUNT_MAX=5

# ============================================================
# Webhook Configuration - CONTATOS
# Contatos agora são enviados via webhook (não mais API Emarsys)
# ============================================================
CONTACTS_WEBHOOK_URL=https://api.hopeoficial.com.br/api/emarsys/contacts2/sync/webhook
# Tipo do cliente enviado no payload do webhook
CONTACTS_WEBHOOK_CLIENT_TYPE=hope
# Header de autenticação do webhook (opcional, ex: Bearer token ou API key)
CONTACTS_WEBHOOK_AUTH_HEADER=
# Timeout em ms para o webhook (padrão: 30000)
CONTACTS_WEBHOOK_TIMEOUT=30000

# Configuração de Monitoramento e Logging
LOG_LEVEL=info

# Configuração de Alertas
ALERT_ERROR_RATE=0.1
ALERT_RESPONSE_TIME=5000
ALERT_MEMORY_USAGE=0.9
ALERT_CONSECUTIVE_ERRORS=5

# Configuração de Cron Jobs
# Cron para sincronização de produtos (padrão: a cada 8 horas)
PRODUCTS_SYNC_CRON=0 */8 * * *
# Cron para delta sync de clientes VTEX Master Data → Webhook (padrão: :00 e :30)
# IMPORTANTE: clientes devem sincronizar ANTES dos pedidos para que o Emarsys
# consiga atrelar os pedidos aos contatos corretos.
CLIENTS_SYNC_CRON=*/30 * * * *
# Cron para sincronização de orders (padrão: :05 e :35 — 5 min após clientes)
# O offset de 5 minutos garante que o cliente já existe no Emarsys quando o pedido chegar.
ORDERS_SYNC_CRON=5,35 * * * *
# Timezone para os cron jobs (padrão: America/Sao_Paulo)
CRON_TIMEZONE=America/Sao_Paulo
# Controle de desativação do cron de orders (true = desativado/pulado, false ou não definido = ativo)
# Quando true, o cron não executa mas continua agendado
ORDERS_SYNC_ENABLED=true
# Habilitar delta sync de clientes Hope (true = ativo, false ou não definido = desabilitado)
CLIENTS_SYNC_ENABLED=false
# Habilitar delta sync de clientes Resort (true = ativo, false ou não definido = desabilitado)
CLIENTS_SYNC_ENABLED_RESORT=false
# Cron exclusivo para Resort (opcional — se vazio usa CLIENTS_SYNC_CRON)
CLIENTS_SYNC_CRON_RESORT=

# SMTP Configuration (opcional, para notificações de alerta)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURE=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_TO=

# Slack Configuration (opcional, para notificações de alerta)
# SLACK_WEBHOOK_URL=
# SLACK_CHANNEL=