{
  "name": "emarsys-server",
  "version": "1.7.0",
  "description": "Servidor Express para integração com Emarsys",
  "main": "server.js",
  "scripts": {
    "start": "node --expose-gc server.js",
    "dev": "nodemon --expose-gc server.js",
    "prod": "pm2 start ecosystem.config.js --env production",
    "prod:dev": "pm2 start ecosystem.config.js --env development",
    "prod:stop": "pm2 stop emarsys-server",
    "prod:restart": "pm2 restart emarsys-server",
    "prod:reload": "pm2 reload emarsys-server",
    "prod:delete": "pm2 delete emarsys-server",
    "prod:logs": "pm2 logs emarsys-server",
    "prod:logs:error": "pm2 logs emarsys-server --err",
    "prod:monit": "pm2 monit",
    "prod:status": "pm2 status",
    "prod:save": "pm2 save",
    "prod:startup": "pm2 startup",
    "prod:reset": "pm2 reset emarsys-server",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:integration": "node test-integration.js"
  },
  "keywords": [
    "emarsys",
    "express",
    "api",
    "integration"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.2",
    "axios-rate-limit": "^1.3.0",
    "axios-retry": "^4.0.0",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^17.2.1",
    "end-of-stream": "^1.4.4",
    "express": "^4.18.2",
    "fs-extra": "^11.3.0",
    "helmet": "^7.1.0",
    "moment": "^2.29.4",
    "pm2": "^5.3.0",
    "ssh2": "^1.16.0",
    "webdav": "^5.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
