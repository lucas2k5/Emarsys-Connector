{
  "name": "emarsys-server",
  "version": "1.4.1",
  "description": "Servidor Express para integração com Emarsys",
  "main": "server.js",
  "scripts": {
    "start": "node --expose-gc server.js",
    "dev": "nodemon --expose-gc server.js",
    "build": "nodemon --expose-gc server.js",
    "pm2:start": "pm2 start server.js --name emarsys-server",
    "pm2:stop": "pm2 stop emarsys-server",
    "pm2:restart": "pm2 restart emarsys-server",
    "pm2:delete": "pm2 delete emarsys-server",
    "pm2:logs": "pm2 logs emarsys-server",
    "pm2:monit": "pm2 monit",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:integration": "node test-integration.js"
  },
  "keywords": [
    "emarsys",
    "express",
    "api",
    "integration"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.2",
    "axios-rate-limit": "^1.3.0",
    "axios-retry": "^4.0.0",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^17.2.1",
    "end-of-stream": "^1.4.4",
    "express": "^4.18.2",
    "fs-extra": "^11.3.0",
    "helmet": "^7.1.0",
    "moment": "^2.29.4",
    "pm2": "^5.3.0",
    "ssh2": "^1.16.0",
    "webdav": "^5.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
