{
  "name": "emarsys-server",
  "version": "1.13.0",
  "description": "Servidor Express para integração com Emarsys",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node --expose-gc --max-old-space-size=3072 server.js",
    "dev": "nodemon --expose-gc --max-old-space-size=3072 server.js",
    "prod": "npm install && pm2 stop emarsys-server && pm2 start ecosystem.config.js --env production || npm install && pm2 start ecosystem.config.js --env production",
    "prod:dev": "npm install && pm2 start ecosystem.config.js --env development",
    "prod:stop": "pm2 stop emarsys-server",
    "prod:restart": "npm install && pm2 restart emarsys-server",
    "prod:reload": "npm install && pm2 reload emarsys-server",
    "prod:delete": "pm2 delete emarsys-server",
    "prod:logs": "pm2 logs emarsys-server",
    "prod:logs:error": "pm2 logs emarsys-server --err",
    "prod:logrotate:setup": "node scripts/setup-pm2-logrotate.js",
    "prod:monit": "pm2 monit",
    "prod:status": "pm2 status",
    "test": "echo \"Error: no test specified\" && exit 1",
    "logs": "tail -f logs/hope-emarsys-$(date +%Y-%m-%d).log",
    "clear-logs": "node scripts/clear-logs.js",
    "cleanup:exports": "node scripts/cleanup-old-exports.js",
    "cleanup:exports:dry": "node scripts/cleanup-old-exports.js --dry-run",
    "cleanup:month": "node scripts/cleanup-old-exports.js",
    "cleanup:install": "sudo bash scripts/install-cleanup-cron.sh",
    "cleanup:logs": "tail -f /var/log/emarsys-cleanup.log",
    "dashboards": "echo 'Dashboards disponíveis: http://localhost:3000/api/metrics/dashboard | http://localhost:3000/api/alerts/dashboard'",
    "monitoring:setup": "mkdir -p logs data && echo 'Sistema de monitoramento configurado!'",
    "postinstall": "node scripts/postinstall.js",
    "deploy": "node scripts/deploy.js",
    "beta:build": "tsc",
    "beta:start": "node dist/server.js",
    "tunnel": "ngrok http --url=dangelo-unadopted-hsiu.ngrok-free.app 3000",
    "sync:products": "node scripts/syncProducts.js",
    "sync:orders": "node scripts/syncOrders.js",
    "sync:orders:historical": "node -e \"require('./scripts/syncOrders').runHistoricalSync()\""
  },
  "keywords": [
    "emarsys",
    "express",
    "api",
    "integration"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.2",
    "axios-rate-limit": "^1.3.0",
    "better-sqlite3": "^11.6.0",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.1",
    "end-of-stream": "^1.4.4",
    "express": "^4.18.2",
    "express-prometheus-middleware": "^1.2.0",
    "fs-extra": "^11.3.0",
    "helmet": "^7.1.0",
    "moment": "^2.29.4",
    "moment-timezone": "^0.6.0",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "pm2": "^5.3.0",
    "prom-client": "^13.2.0",
    "ssh2": "^1.16.0",
    "ssh2-sftp-client": "^12.1.1",
    "webdav": "^5.7.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
